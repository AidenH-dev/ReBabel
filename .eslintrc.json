{
  "extends": ["next/core-web-vitals", "prettier"],
  "rules": {
    "no-unused-vars": ["warn", { "argsIgnorePattern": "^_" }],
    "no-console": ["warn", { "allow": ["warn", "error"] }],
    "max-lines": [
      "warn",
      { "max": 400, "skipBlankLines": true, "skipComments": true }
    ]
  }
}
